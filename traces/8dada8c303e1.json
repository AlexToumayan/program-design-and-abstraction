{"code": "def pair(a, b):\n    def get(index):\n        if index == 0:\n            return a\n        elif index == 1:\n            return b\n    return get\n\ndef select(p, i):\n    return p(i)\n\ndef make_frac(n, d):\n    return pair(n, d)\n\ndef frac_numer(x):\n    return select(x, 0)\n\ndef frac_denom(x):\n    return select(x, 1)\n\ndef frac_add(x, y):\n    nx, dx = frac_numer(x), frac_denom(x)\n    ny, dy = frac_numer(y), frac_denom(y)\n    return make_frac(nx * dy + ny * dx, dx * dy)", "trace": [{"line": 1, "event": "step_line", "func_name": "<module>", "globals": {}, "ordered_globals": [], "stack_to_render": [], "heap": {}, "stdout": ""}, {"line": 9, "event": "step_line", "func_name": "<module>", "globals": {"pair": ["REF", 1]}, "ordered_globals": ["pair"], "stack_to_render": [], "heap": {"1": ["FUNCTION", "pair(a, b)", null]}, "stdout": ""}, {"line": 12, "event": "step_line", "func_name": "<module>", "globals": {"pair": ["REF", 1], "select": ["REF", 2]}, "ordered_globals": ["pair", "select"], "stack_to_render": [], "heap": {"1": ["FUNCTION", "pair(a, b)", null], "2": ["FUNCTION", "select(p, i)", null]}, "stdout": ""}, {"line": 15, "event": "step_line", "func_name": "<module>", "globals": {"pair": ["REF", 1], "select": ["REF", 2], "make_frac": ["REF", 3]}, "ordered_globals": ["pair", "select", "make_frac"], "stack_to_render": [], "heap": {"1": ["FUNCTION", "pair(a, b)", null], "2": ["FUNCTION", "select(p, i)", null], "3": ["FUNCTION", "make_frac(n, d)", null]}, "stdout": ""}, {"line": 18, "event": "step_line", "func_name": "<module>", "globals": {"pair": ["REF", 1], "select": ["REF", 2], "make_frac": ["REF", 3], "frac_numer": ["REF", 4]}, "ordered_globals": ["pair", "select", "make_frac", "frac_numer"], "stack_to_render": [], "heap": {"1": ["FUNCTION", "pair(a, b)", null], "2": ["FUNCTION", "select(p, i)", null], "3": ["FUNCTION", "make_frac(n, d)", null], "4": ["FUNCTION", "frac_numer(x)", null]}, "stdout": ""}, {"line": 21, "event": "step_line", "func_name"