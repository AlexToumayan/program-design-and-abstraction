{"code": "def count_a(chunk):\n    return chunk.count(\"a\")\n\ndef run_task(name, chunk, fail=False):\n    if fail:\n        return {\"task\": name, \"status\": \"failed\", \"result\": None}\n    return {\"task\": name, \"status\": \"done\", \"result\": count_a(chunk)}\n\nchunks = {\n    \"task-1\": \"Google MapReduce\",\n    \"task-2\": \"Is a Big Data framework\",\n    \"task-3\": \"For batch processing\",\n}\n\nresults = []\nresults.append(run_task(\"task-1\", chunks[\"task-1\"]))\nresults.append(run_task(\"task-2\", chunks[\"task-2\"], fail=True))\nresults.append(run_task(\"task-3\", chunks[\"task-3\"]))\n\nfor record in results:\n    if record[\"status\"] == \"failed\":\n        name = record[\"task\"]\n        record[\"status\"] = \"done\"\n        record[\"result\"] = count_a(chunks[name])\n\ntotal = 0\nfor record in results:\n    total = total + record[\"result\"]\n\nprint(total)", "trace": [{"line": 1, "event": "step_line", "func_name": "<module>", "globals": {}, "ordered_globals": [], "stack_to_render": [], "heap": {}, "stdout": ""}, {"line": 4, "event": "step_line", "func_name": "<module>", "globals": {"count_a": ["REF", 1]}, "ordered_globals": ["count_a"], "stack_to_render": [], "heap": {"1": ["FUNCTION", "count_a(chunk)", null]}, "stdout": ""}, {"line": 10, "event": "step_line", "func_name": "<module>", "globals": {"count_a": ["REF", 1], "run_task": ["REF", 2]}, "ordered_globals": ["count_a", "run_task"], "stack_to_render": [], "heap": {"1": ["FUNCTION", "count_a(chunk)", null], "2": ["FUNCTION", "run_task(name, chunk, fail)", null]}, "stdout": ""}, {"line": 11, "event": "step_line", "func_name": "<module>", "globals": {"count_a": ["REF", 1], "run_task": ["REF", 2]}, "ordered_globals": ["count_a", "run_task"], "stack_to_render": [], "heap": {"1": ["FUNCTION", "count_a(chunk)", null], "2": ["FUNCTION", "run_task(name, chunk, fail)", null]}, "stdout": ""}, {"line": 12, "event": "step_line", "func_name": "<module>", "globals": {"count_a": ["REF", 1], "run