{"code": "class Number:\n    def __add__(self, other):\n        if self.type_tag == other.type_tag:\n            return self.add(other)\n        elif (self.type_tag, other.type_tag) in self.adders:\n            return self.cross_apply(other, self.adders)\n\n    def cross_apply(self, other, cross_fns):\n        cross_fn = cross_fns[(self.type_tag, other.type_tag)]\n        return cross_fn(self, other)\n\nclass Cents(Number):\n    type_tag = 'cents'\n\n    def __init__(self, cents):\n        self.cents = cents\n\n    def __repr__(self):\n        return 'Cents({0})'.format(self.cents)\n\n    def add(self, other):\n        return Cents(self.cents + other.cents)\n\nclass Dollars(Number):\n    type_tag = 'dollars'\n\n    def __init__(self, dollars):\n        self.dollars = dollars\n\n    def __repr__(self):\n        return 'Dollars({0})'.format(self.dollars)\n\n    def add(self, other):\n        return Dollars(self.dollars + other.dollars)\n\ndef add_cents_and_dollars(c, d):\n    return Cents(c.cents + d.dollars * 100)\n\ndef add_dollars_and_cents(d, c):\n    return add_cents_and_dollars(c, d)\n\nNumber.adders = {\n    ('cents', 'dollars'): add_cents_and_dollars,\n    ('dollars', 'cents'): add_dollars_and_cents,\n}", "trace": [{"line": 1, "event": "step_line", "func_name": "<module>", "globals": {}, "ordered_globals": [], "stack_to_render": [], "heap": {}, "stdout": ""}, {"line": 12, "event": "step_line", "func_name": "<module>", "globals": {"Number": ["REF", 1]}, "ordered_globals": ["Number"], "stack_to_render": [], "heap": {"1": ["CLASS", "Number", [], ["__add__", ["REF", 2]], ["cross_apply", ["REF", 3]]], "2": ["FUNCTION", "__add__(self, other)", null], "3": ["FUNCTION", "cross_apply(self, other, cross_fns)", null]}, "stdout": ""}, {"line": 24, "event": "step_line", "func_name": "<module>", "globals": {"Number": ["REF", 1], "Cents": ["REF", 4]}, "ordered_globals": ["Number", "Cents"], "stack_to_render": [], "heap": {"1": ["CLASS", "Number", [], ["__add__", ["REF", 2]],