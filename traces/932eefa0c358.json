{"code": "def match(pattern, data, env):\n    \"\"\"Try to extend env so that pattern matches data. Return env or None.\"\"\"\n    if isinstance(pattern, str) and pattern.startswith(\"?\"):\n        if pattern in env and env[pattern] != data:\n            return None\n        env = dict(env)\n        env[pattern] = data\n        return env\n    if isinstance(pattern, list) and isinstance(data, list):\n        if len(pattern) == 3 and pattern[1] == \".\":\n            env = match(pattern[0], data[0], env) if data else None\n            if env is None:\n                return None\n            return match(pattern[2], data[1:], env)\n        if len(pattern) != len(data):\n            return None\n        for p, d in zip(pattern, data):\n            env = match(p, d, env)\n            if env is None:\n                return None\n        return env\n    return env if pattern == data else None\n\n\nPARENTS = [\n    (\"parent\", \"abraham\", \"barack\"),\n    (\"parent\", \"abraham\", \"clinton\"),\n    (\"parent\", \"delano\", \"herbert\"),\n    (\"parent\", \"fillmore\", \"abraham\"),\n    (\"parent\", \"fillmore\", \"delano\"),\n    (\"parent\", \"fillmore\", \"grover\"),\n    (\"parent\", \"eisenhower\", \"fillmore\"),\n]\n\n\nDOGS = [\n    [\"dog\", [\"name\", \"abraham\"], [\"color\", \"white\"]],\n    [\"dog\", [\"name\", \"barack\"], [\"color\", \"tan\"]],\n    [\"dog\", [\"name\", \"clinton\"], [\"color\", \"white\"]],\n    [\"dog\", [\"name\", \"delano\"], [\"color\", \"white\"]],\n    [\"dog\", [\"name\", \"eisenhower\"], [\"color\", \"tan\"]],\n    [\"dog\", [\"name\", \"fillmore\"], [\"color\", \"brown\"]],\n    [\"dog\", [\"name\", \"grover\"], [\"color\", \"tan\"]],\n    [\"dog\", [\"name\", \"herbert\"], [\"color\", \"brown\"]],\n]", "trace": [{"line": 1, "event": "step_line", "func_name": "<module>", "globals": {}, "ordered_globals": [], "stack_to_render": [], "heap": {}, "stdout": ""}, {"line": 25, "event": "step_line", "func_name": "<module>", "globals